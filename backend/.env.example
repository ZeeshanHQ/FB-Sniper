SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:3000/auth/callback

# ── Facebook browser sessions (Playwright group posting) ─────────────────────
# Generate once:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=your_fernet_key_here
# Run group automation browsers headless (true) or visible (false).
FB_BROWSER_HEADLESS=true

# ── Campaign Worker (all optional — defaults shown) ──────────────────────────
WORKER_POLL_INTERVAL=60      # seconds between polls
WORKER_MAX_CONCURRENT=3      # max campaigns executing in parallel
WORKER_MAX_RETRIES=3         # attempts before permanent failure
WORKER_BATCH_SIZE=10         # campaigns fetched per poll cycle
